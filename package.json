{
  "name": "agentpay",
  "version": "0.1.0",
  "private": true,
  "description": "Owner-authorized cross-chain payments for AI agents.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "canary:mainnet": "tsx scripts/celo-mainnet-canary.ts",
    "contracts:build": "cd contracts && forge build",
    "contracts:bytecode": "npm run contracts:build && node scripts/export-agentpay-bytecode.mjs",
    "contracts:deploy:celo": "npm run contracts:build && tsx scripts/deploy-celo-factory.ts --broadcast",
    "contracts:deploy:celo:simulate": "npm run contracts:build && tsx scripts/deploy-celo-factory.ts",
    "contracts:deploy:celo:sepolia": "cd contracts && forge script script/DeployAgentPayAccountV2.s.sol:DeployAgentPayAccountV2 --rpc-url \"$CELO_SEPOLIA_RPC_URL\" --broadcast",
    "demo:local": "tsx scripts/demo-agentpay-flow.ts",
    "erc8004": "tsx scripts/erc8004-registration.ts",
    "lint": "npm run lint --workspaces --if-present",
    "manifest:mainnet:shadow": "node scripts/generate-mainnet-shadow-manifest.mjs",
    "manifest:mainnet:activate": "node scripts/mainnet-activation-manifest.mjs",
    "release:smoke": "node scripts/smoke-agentpay-release.mjs",
    "test": "npm run test --workspaces --if-present && npm run test:scripts && npm run test:contracts",
    "test:e2e": "playwright test --config apps/setup-web/playwright.config.ts",
    "test:e2e:onboarding": "playwright test --config apps/setup-web/playwright.config.ts --grep \"production onboarding\"",
    "test:contracts": "cd contracts && forge test",
    "test:scripts": "node --test scripts/*.test.mjs && tsx --test \"scripts/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@celo/attribution-tags": "^0.3.0",
    "@noble/hashes": "^2.2.0",
    "@x402/core": "^2.18.0",
    "@x402/evm": "^2.18.0",
    "@supabase/supabase-js": "^2.110.0",
    "ethers": "^6.17.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
