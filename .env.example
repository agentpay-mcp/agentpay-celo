SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Production HTTP surface only; keep these aliases isolated from staging.
# SUPABASE_PRODUCTION_URL=
# SUPABASE_PRODUCTION_SERVICE_ROLE_KEY=
# DIRECT_URL_PRODUCTION= # migration-admin only; never load into the app

CELO_RPC_URL=
CELO_MAINNET_RPC_URL=
CELO_MAINNET_RPC_FALLBACK_URL=https://forno.celo.org
CELO_ATTRIBUTION_TAG=
CELO_SEPOLIA_RPC_URL=
BASE_RPC_URL=

EXECUTOR_PRIVATE_KEY=
SETUP_DEPLOYER_PRIVATE_KEY=
AGENTPAY_OWNER_ADDRESS=
AGENTPAY_EXECUTOR_ADDRESS=
AGENTPAY_HOME_CHAIN_ID=
AGENTPAY_CONSUMER_MCP_URL=https://wallet.agentpay.site/celo/mcp
AGENTPAY_PAID_MCP_URL=https://mcp.agentpay.site/celo/mcp
AGENTPAY_PUBLIC_SETUP_URL=https://wallet.agentpay.site/celo/setup
AGENTPAY_PUBLIC_REVIEW_URL=https://wallet.agentpay.site/celo/review
# Publish only after AGENTPAY_ERC8004_AGENT_WALLET is a deployed mainnet AgentPay account.
AGENTPAY_ERC8004_ENABLED=false
AGENTPAY_ERC8004_AGENT_WALLET=
# Set after the Identity Registry registration transaction confirms.
AGENTPAY_ERC8004_AGENT_ID=
# Short-lived operator inputs used only by `npm run erc8004 -- set-wallet`.
AGENTPAY_ERC8004_WALLET_PROOF_DEADLINE=
AGENTPAY_ERC8004_WALLET_PROOF_SIGNATURE=
AGENTPAY_HTTP_MODE=
AGENTPAY_ENVIRONMENT=
AGENTPAY_MAINNET_MANIFEST_PATH=
AGENTPAY_ONBOARDING_MANIFEST_PATH=
AGENTPAY_ONBOARDING_MANIFEST_SHA256=
AGENTPAY_ACCOUNT_RUNTIME_ARTIFACT_PATH=
AGENTPAY_FACTORY_ADDRESS=
AGENTPAY_FACTORY_RUNTIME_CODE_HASH=
AGENTPAY_SETUP_SPONSOR_ADDRESS=
AGENTPAY_SETUP_SUPABASE_PROJECT_REF=
AGENTPAY_SETUP_MODE=OFF
AGENTPAY_SESSION_HASH_KEY=
AGENTPAY_REVIEW_TOKEN_SECRET=
# 32-byte hex key; required before CANARY/PUBLIC invoice outbox execution.
AGENTPAY_RAW_TX_ENCRYPTION_KEY=
AGENTPAY_ACCOUNT_ADDRESS=
AGENTPAY_CELO_USDC_ADDRESS=
AGENTPAY_CELO_USDT_ADDRESS=
AGENTPAY_CELO_USDM_ADDRESS=
AGENTPAY_CELO_SEPOLIA_USDC_ADDRESS=
AGENTPAY_CELO_SEPOLIA_USDT_ADDRESS=
AGENTPAY_CELO_SEPOLIA_USDM_ADDRESS=

# Setup web can read packaged bytecode from a file or inline bytecode.
AGENTPAY_ACCOUNT_BYTECODE_PATH=
AGENTPAY_ACCOUNT_BYTECODE=
AGENTPAY_ACCOUNT_VERSION=v2
# Required for Celo mainnet deployment; use npm run contracts:bytecode output.
AGENTPAY_ACCOUNT_BYTECODE_HASH=
AGENTPAY_INITIAL_ROUTE_TARGETS=

SETUP_WEB_URL=
SETUP_WEB_PORT=

LIFI_API_KEY=
LIFI_BASE_URL=
X402_BAZAAR_FACILITATOR_URL=

# Public x402 seller payment gate on Celo.
AGENTPAY_A2MCP_PAYMENT_ENABLED=false
AGENTPAY_A2MCP_PAYMENT_PAY_TO=
AGENTPAY_A2MCP_PAYMENT_PRICE=$0.01
AGENTPAY_A2MCP_PAYMENT_NETWORK=eip155:42220
AGENTPAY_A2MCP_PAYMENT_ASSET=0xcebA9300f2b948710d2653dD7B07f33A8B32118C
AGENTPAY_A2MCP_PAYMENT_MAX_TIMEOUT_SECONDS=300
AGENTPAY_A2MCP_PAYMENT_ASSET_DECIMALS=6
AGENTPAY_A2MCP_PAYMENT_SYNC_SETTLE=true
AGENTPAY_A2MCP_PAYMENT_ASSET_TRANSFER_METHOD=eip3009
AGENTPAY_A2MCP_PAYMENT_FACILITATOR_URL=https://api.x402.celo.org
AGENTPAY_CELO_X402_API_KEY=
