# Include inside the existing wallet.agentpay.site TLS server. The review
# token remains in the URL fragment and is forwarded only as a request header.

location = /celo/review {
    limit_except GET { deny all; }
    proxy_pass http://127.0.0.1:3103;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $remote_addr;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Connection "";
    add_header Cache-Control "no-store" always;
    add_header Referrer-Policy "no-referrer" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
}

location = /celo/api/payment-review {
    limit_except GET POST { deny all; }
    client_max_body_size 4k;
    client_body_timeout 10s;
    proxy_pass http://127.0.0.1:3103;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $remote_addr;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Connection "";
    proxy_read_timeout 30s;
    proxy_send_timeout 30s;
    add_header Cache-Control "no-store" always;
    add_header Referrer-Policy "no-referrer" always;
    add_header X-Content-Type-Options "nosniff" always;
}
