# Include this block inside the existing wallet.agentpay.site TLS server.
# Provision the trusted proxy identity from the onboarding web secret boundary.
location ^~ /celo/setup {
    client_max_body_size 4k;
    client_body_timeout 10s;

    proxy_pass http://127.0.0.1:3104;
    proxy_http_version 1.1;
    proxy_set_header Host wallet.agentpay.site;
    proxy_set_header X-Forwarded-For $remote_addr;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-AgentPay-Client-Address $remote_addr;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-AgentPay-Proxy-Identity "__PROVISION_TRUSTED_PROXY_IDENTITY__";
    proxy_set_header Connection "";
    proxy_buffering off;
    proxy_read_timeout 30s;
    proxy_send_timeout 30s;
    proxy_hide_header Access-Control-Allow-Origin;

    add_header Cache-Control "no-store" always;
    add_header Referrer-Policy "no-referrer" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
}
