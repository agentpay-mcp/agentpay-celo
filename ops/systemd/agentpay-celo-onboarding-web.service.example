[Unit]
Description=AgentPay Celo production onboarding web (OFF by default)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=agentpay-celo-web
Group=agentpay-celo-web
WorkingDirectory=/opt/agentpay-celo
Environment=NODE_ENV=production
EnvironmentFile=/opt/agentpay-celo/private/web/onboarding.env
Environment=SETUP_WEB_PORT=3104
ExecStart=__RELEASE_ROOT__/node_modules/.bin/tsx __RELEASE_ROOT__/apps/setup-web/src/onboarding/start.ts
Restart=always
RestartSec=5
UMask=0027
NoNewPrivileges=true
PrivateTmp=true
PrivateDevices=true
ProtectSystem=strict
ProtectHome=true
ProtectKernelTunables=true
ProtectControlGroups=true
ProtectKernelModules=true
ProtectKernelLogs=true
ProtectClock=true
ProtectHostname=true
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
SocketBindDeny=any
SocketBindAllow=tcp:3104
LockPersonality=true
RestrictSUIDSGID=true
CapabilityBoundingSet=
AmbientCapabilities=
ReadOnlyPaths=__RELEASE_ROOT__ /opt/agentpay-celo/private/web
InaccessiblePaths=/opt/agentpay-celo/private/worker /opt/agentpay-celo/private/rotator.env

[Install]
WantedBy=multi-user.target
