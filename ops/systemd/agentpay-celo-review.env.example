# Install as /opt/agentpay-celo/private/review/runtime.env with mode 0640,
# owned by root:agentpay-celo-review. This boundary must never receive an
# executor key or raw-transaction encryption key.

AGENTPAY_ENVIRONMENT=production
AGENTPAY_HOME_CHAIN_ID=42220
AGENTPAY_ACCOUNT_VERSION=v2
AGENTPAY_EXECUTION_MODE=OFF
AGENTPAY_A2MCP_PAYMENT_ENABLED=false
AGENTPAY_SETUP_SUPABASE_PROJECT_REF=hxnrqujmyltkumfipkuk
AGENTPAY_MAINNET_MANIFEST_PATH=/opt/agentpay-celo/releases/@RELEASE_COMMIT@/ops/manifests/celo-mainnet.activated.json
AGENTPAY_REVIEW_MANIFEST_SHA256=9e8a398842e4c6fc2c10a730d09b1d0859862e067387c6de387c0c1cd00c41d6
AGENTPAY_RELEASE_COMMIT=@RELEASE_COMMIT@
SETUP_WEB_URL=https://wallet.agentpay.site/celo/review

SUPABASE_PRODUCTION_URL=
SUPABASE_PRODUCTION_SERVICE_ROLE_KEY=
AGENTPAY_REVIEW_TOKEN_SECRET=
