# Install as /opt/agentpay-celo/private/mcp-public/runtime.env with mode 0640,
# owned by root:agentpay-celo-public. Only this boundary receives the executor
# and raw-transaction encryption keys.

NODE_ENV=production
AGENTPAY_ENVIRONMENT=production
AGENTPAY_HTTP_MODE=public
AGENTPAY_HOME_CHAIN_ID=42220
AGENTPAY_ACCOUNT_VERSION=v2
AGENTPAY_EXECUTION_MODE=OFF
AGENTPAY_A2MCP_PAYMENT_ENABLED=false
AGENTPAY_ERC8004_ENABLED=false

AGENTPAY_MAINNET_MANIFEST_PATH=/opt/agentpay-celo/releases/@RELEASE_COMMIT@/ops/manifests/celo-mainnet.activated.json
AGENTPAY_ONBOARDING_MANIFEST_PATH=/opt/agentpay-celo/manifests/celo-mainnet-onboarding.canary.json
AGENTPAY_ONBOARDING_MANIFEST_SHA256=c50a966a62f7ff9ac1ce6d498269ceef3cd8fe796f62346cf4ff9f8e81e5e7ab
AGENTPAY_FACTORY_ADDRESS=0x7e1d7834e57f9e16393329Ba37a7c5e7A39f6735
AGENTPAY_FACTORY_RUNTIME_CODE_HASH=0xacf158d0950bc04fe98bb801a45eced68265b81b22d820e735a69037d2dd2254
AGENTPAY_SETUP_SPONSOR_ADDRESS=0x72936d76E840ddBB18976705779b6E24834B4d93
AGENTPAY_SETUP_SUPABASE_PROJECT_REF=hxnrqujmyltkumfipkuk
AGENTPAY_SETUP_MODE=CANARY

AGENTPAY_CONSUMER_MCP_URL=https://wallet.agentpay.site/celo/mcp
AGENTPAY_PAID_MCP_URL=https://mcp.agentpay.site/celo/mcp
AGENTPAY_PUBLIC_SETUP_URL=https://wallet.agentpay.site/celo/setup
AGENTPAY_PUBLIC_REVIEW_URL=https://wallet.agentpay.site/celo/review
SETUP_WEB_URL=https://wallet.agentpay.site/celo/review

SUPABASE_PRODUCTION_URL=
SUPABASE_PRODUCTION_SERVICE_ROLE_KEY=
CELO_MAINNET_RPC_URL=
CELO_MAINNET_RPC_FALLBACK_URL=https://forno.celo.org
CELO_ATTRIBUTION_TAG=
EXECUTOR_PRIVATE_KEY=
AGENTPAY_EXECUTOR_ADDRESS=0x645d39b3943D27cfE53184a446f551a69a4b1FDe
AGENTPAY_SESSION_HASH_KEY=
AGENTPAY_REVIEW_TOKEN_SECRET=
AGENTPAY_RAW_TX_ENCRYPTION_KEY=

X402_BAZAAR_FACILITATOR_URL=https://api.x402.celo.org
AGENTPAY_A2MCP_PAYMENT_PRICE=$0.01
AGENTPAY_A2MCP_PAYMENT_NETWORK=eip155:42220
AGENTPAY_A2MCP_PAYMENT_ASSET=0xcebA9300f2b948710d2653dD7B07f33A8B32118C
AGENTPAY_A2MCP_PAYMENT_ASSET_DECIMALS=6
AGENTPAY_A2MCP_PAYMENT_SYNC_SETTLE=true
AGENTPAY_A2MCP_PAYMENT_ASSET_TRANSFER_METHOD=eip3009
AGENTPAY_A2MCP_PAYMENT_FACILITATOR_URL=https://api.x402.celo.org
