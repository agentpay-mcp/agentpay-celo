[Unit]
Description=AgentPay Celo public MCP server (production OFF)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=agentpay-celo-public
Group=agentpay-celo-public
WorkingDirectory=/opt/agentpay-celo/releases/@RELEASE_COMMIT@
Environment=NODE_ENV=production
EnvironmentFile=/opt/agentpay-celo/private/mcp-public/runtime.env
Environment=AGENTPAY_HTTP_MODE=public
ExecStart=/opt/agentpay-celo/releases/@RELEASE_COMMIT@/packages/cli/dist/index.js serve-http --host 127.0.0.1 --port 3101
Restart=always
RestartSec=5
UMask=0027
NoNewPrivileges=true
PrivateTmp=true
PrivateDevices=true
ProtectSystem=strict
ProtectHome=true
ProtectKernelTunables=true
ProtectControlGroups=true
ProtectKernelModules=true
ProtectKernelLogs=true
ProtectClock=true
ProtectHostname=true
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
SocketBindDeny=any
SocketBindAllow=tcp:3101
LockPersonality=true
RestrictSUIDSGID=true
CapabilityBoundingSet=
AmbientCapabilities=
ReadOnlyPaths=/opt/agentpay-celo/releases/@RELEASE_COMMIT@ /opt/agentpay-celo/private/mcp-public /opt/agentpay-celo/manifests
InaccessiblePaths=/opt/agentpay-celo/private/mcp-consumer /opt/agentpay-celo/private/review /opt/agentpay-celo/private/web /opt/agentpay-celo/private/worker /opt/agentpay-celo/private/rotator.env

[Install]
WantedBy=multi-user.target
