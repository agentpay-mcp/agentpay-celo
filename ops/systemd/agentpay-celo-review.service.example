[Unit]
Description=AgentPay Celo Review & Sign (production OFF)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=agentpay-celo-review
Group=agentpay-celo-review
WorkingDirectory=/opt/agentpay-celo/releases/@RELEASE_COMMIT@
Environment=NODE_ENV=production
EnvironmentFile=/opt/agentpay-celo/private/review/runtime.env
ExecStart=/opt/agentpay-celo/releases/@RELEASE_COMMIT@/node_modules/.bin/tsx scripts/celo-review-web-start.ts
Restart=always
RestartSec=5
UMask=0027
NoNewPrivileges=true
PrivateTmp=true
PrivateDevices=true
ProtectSystem=strict
ProtectHome=true
ProtectKernelTunables=true
ProtectControlGroups=true
ProtectKernelModules=true
ProtectKernelLogs=true
ProtectClock=true
ProtectHostname=true
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
SocketBindDeny=any
SocketBindAllow=tcp:3103
LockPersonality=true
RestrictSUIDSGID=true
CapabilityBoundingSet=
AmbientCapabilities=
ReadOnlyPaths=/opt/agentpay-celo/releases/@RELEASE_COMMIT@ /opt/agentpay-celo/private/review
InaccessiblePaths=/opt/agentpay-celo/private/mcp-public /opt/agentpay-celo/private/mcp-consumer /opt/agentpay-celo/private/web /opt/agentpay-celo/private/worker /opt/agentpay-celo/private/rotator.env

[Install]
WantedBy=multi-user.target
